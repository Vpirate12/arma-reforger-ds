# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Steam username — required to download the DS binary (app 1874900) on first run.
# After the DS binary is on the arma_serverdata volume, USERNAME is no longer used
# (the entrypoint skips SteamCMD when the binary is already present).
USERNAME=your_steam_username

# Steam password — only needed for the one-time DS binary download.
# Remove after first successful container start.
# PASSWRD=your_steam_password

# Steam Guard code — if your account uses the mobile authenticator, provide the
# 5-character code here for the non-interactive container login.
# STEAM_GUARD_CODE=XXXXX

# Secret key for the scenario-manager Flask session.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_string

# Your server's public IP address (injected into server.json publicAddress).
# Run: curl -s https://api.ipify.org
PUBLIC_IP=your.external.ip.address

# Cloudflare Tunnel token — from Cloudflare Zero Trust dashboard.
# Zero Trust → Networks → Tunnels → Create a tunnel → copy the token.
# The tunnel routes your chosen subdomain (e.g. arma.yourdomain.com) to
# http://scenario-manager:5000 with automatic HTTPS at the Cloudflare edge.
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# Public URL of the scenario manager — used to build OAuth redirect URIs.
OAUTH_BASE_URL=https://admin.yourdomain.com

# Discord OAuth app — discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Optional: restrict login to members of a specific Discord server.
# Right-click your server in Discord → Copy Server ID (requires Developer Mode).
DISCORD_GUILD_ID=your_discord_guild_id

# Google OAuth app — console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Comma-separated list of Google email addresses allowed to log in.
ALLOWED_GOOGLE_EMAILS=admin@example.com,other@example.com
