# Scenario Manager Environment Variables

# IMPORTANT: Change these before deploying to production

# Secret key for session encryption (use a random string)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-to-something-random

# Path where scenarios are stored
# On Unraid: /mnt/user/scenarios
SCENARIOS_PATH=/scenarios

# Flask environment
# Options: production, development
FLASK_ENV=production
